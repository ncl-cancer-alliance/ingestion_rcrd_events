# Snowflake Connection Configuration
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!

# Snowflake Account (e.g., your-org.eu-west-1 or xy12345)
SNOWFLAKE_ACCOUNT=your-account-here

# Snowflake Username
SNOWFLAKE_USER=your-nhs-email

# Snowflake Role (Code requires at least ENGINEER)
SNOWFLAKE_ROLE=ENGINEER

# Snowflake Warehouse (e.g., NCL_ANALYTICS_XS)
SNOWFLAKE_WAREHOUSE=NCL_ANALYTICS_XS

# One Drive Configurations
# Folder name for the team OneDrive root
NHS_ONEDRIVE_DIR = "OneDrive - NHS"
# Folder for the NDRS Files (Must be added as a shortcut)
DATA_SHAREPOINT_DIR = "NDRS data sharing - Data_Extracts"

# Destination Settings (See README for setup)
SFCLI_CONNECTION_NAME = "conn_rcrd_events"
DATABASE = "DATA_LAKE__NCL"
SCHEMA = "CANCER__RCRD_EVENTS"

#Note the table names for the national tables are derived in the code from the file name
TABLE_NAME_CA = "CANCER_ALLIANCE__RCRD_INC_TRT"

STAGE_NAME_EXAMPLE = "RCRD_EVENTS_EXAMPLE"
STAGE_NAME_NATIONAL = "RCRD_EVENTS_NATIONAL"
STAGE_NAME_CA = "RCRD_EVENTS_CA"

#File formats defined in the Snowflake schema
#Defines how to read the csv files (i.e. delimiters)
FILE_FORMAT_INFER_SCHEMA = "rcrd_events_infer_schema"
FILE_FORMAT_LOAD_STAGE_DATA = "rcrd_events_load_stage_data"

#When set to True, files that already exist in the stage will be reuploaded
INGESTION_OVERWRITE = "False"
#When set to True, all national files are ingested, otherwise only the Inc_Trt data file is
INGEST_ALL_NATIONAL_FILES = "False"